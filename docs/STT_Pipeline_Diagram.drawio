                </mxCell>
                <mxCell id="p2_col1_body" value="&lt;font color=&quot;#cc0000&quot;&gt;✗&lt;/font&gt; Fixed audio encoder&lt;br&gt;&lt;font color=&quot;#cc0000&quot;&gt;✗&lt;/font&gt; No language understanding&lt;br&gt;&lt;font color=&quot;#cc0000&quot;&gt;✗&lt;/font&gt; Cannot reason about context&lt;br&gt;&lt;font color=&quot;#cc0000&quot;&gt;✗&lt;/font&gt; Struggles with code-switching&lt;br&gt;&lt;font color=&quot;#00aa00&quot;&gt;✓&lt;/font&gt; Fast inference" style="text;html=1;align=left;verticalAlign=top;fontSize=12;strokeColor=none;fillColor=none;spacingLeft=15;spacingTop=5;lineHeight=1.5;" vertex="1" parent="p2_1">
